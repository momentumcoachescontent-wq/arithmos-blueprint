# Variables de Entorno — Arithmos

# ─── Supabase ───────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Stripe (Monetización) ──────────────────────────────────────────────────
# Clave pública de Stripe (safe para el frontend)
VITE_STRIPE_PUBLIC_KEY=pk_live_xxxxx

# ID del precio del plan Premium mensual (creado en el dashboard de Stripe)
VITE_STRIPE_PRICE_ID=price_xxxxx

# ─── Variables de Servidor (Supabase Edge Functions — NO exponer en frontend) ─
# Se configuran como Secrets en: Supabase Dashboard > Settings > Edge Functions
# STRIPE_SECRET_KEY=sk_live_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── n8n Webhook ────────────────────────────────────────────────────────────
VITE_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/arithmos
